{
    "name": "atx-digital/ticketing-connect",
    "description": "WordPress companion plugin for atx-digital/ticketing: mirrors published events and hands ticket purchases to the Laravel checkout.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "AtxDigitalTicketing\\": "src/"
        }
    },
    "scripts": {
        "lint": "parallel-lint src atx-digital-ticketing-connect.php templates",
        "phpcs": "phpcs",
        "phpcs:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
